{
  "permissions": {
    "allow": ["Bash(npm run *)", "Bash(git add *)", "Bash(git commit *)"],
    "deny": [
      "Read(./.env)",
      "Read(./.env.local)",
      "Read(./secrets/**)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "npx prettier --write $CLAUDE_TOOL_RESULT_FILE_PATH"
          }
        ]
      }
    ]
  }
}
